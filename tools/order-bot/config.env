# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Tokopedia API Credentials
# Get from seller.tokopedia.com > Settings > API Integration
TOPED_SHOP_ID=YOUR_SHOP_ID
TOPED_CLIENT_ID=YOUR_CLIENT_ID
TOPED_CLIENT_SECRET=YOUR_CLIENT_SECRET

# TikTok Shop API Credentials
# Get from seller.tiktok.com > Settings > API Integration
TIKTOK_SHOP_ID=YOUR_SHOP_ID
TIKTOK_APP_KEY=YOUR_APP_KEY
TIKTOK_APP_SECRET=YOUR_APP_SECRET

# Notification Settings
NOTIFY_NEW_ORDER=true
NOTIFY_PAYMENT_CONFIRMED=true
NOTIFY_ORDER_SHIPPED=true
NOTIFY_ORDER_CANCELLED=true
NOTIFY_LOW_STOCK=true
NOTIFY_DAILY_SUMMARY=true

# Summary Settings
DAILY_SUMMARY_TIME=21:00
STORE_NAME=[Online Store Name]
STORE_LOCATION=Bandung

# Demo Mode
# Set to true when API credentials not yet available
# Bot will generate sample notifications every 2 hours
DEMO_MODE=true
